# =====================================================================
# Auris Frota — Backend (.env)
# =====================================================================
# Preencha com as credenciais do seu projeto Supabase.
# No painel: Project Settings → Database → Connection string
#
# DATABASE_URL  → Session pooler (porta 6543, host *.pooler.supabase.com)
#                  Adicione ?pgbouncer=true no final.
#
# DIRECT_URL    → Direct connection (porta 5432, host db.<ref>.supabase.co)
#                  Usada apenas para rodar migrations (prisma migrate).
# =====================================================================

DATABASE_URL=
DIRECT_URL=
